{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C64 Program",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build-single-prg.sh",
            "args": [
                "${file}",
                "${workspaceFolder}/bin/output.prg"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run in VICE",
            "type": "shell",
            "command": "x64",
            "args": [
                "-autostartprgmode",
                "1",
                "-autostart",
                "${workspaceFolder}/bin/output.prg"
            ],
            "dependsOn": "Build C64 Program"
        },
        {
            "label": "Build Final Lesson 073",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/build-single-prg.sh",
            "args": [
                "${workspaceFolder}/src/lessons/073-nemici-multipli-pattern-avanzati/main.asm",
                "${workspaceFolder}/bin/output.prg"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run Final Lesson 073 in VICE",
            "type": "shell",
            "command": "x64",
            "args": [
                "-autostartprgmode",
                "1",
                "-autostart",
                "${workspaceFolder}/bin/output.prg"
            ],
            "dependsOn": "Build Final Lesson 073"
        }
    ]
}
