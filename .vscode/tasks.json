{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C64 Program",
            "type": "shell",
            "command": "64tass",
            "args": [
                "--cbm-prg",
                "-o",
                "${workspaceFolder}/bin/output.prg",
                "${file}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Run in VICE",
            "type": "shell",
            "command": "x64",
            "args": ["${workspaceFolder}/bin/output.prg"],
            "dependsOn": "Build C64"
        }
    ]
}
