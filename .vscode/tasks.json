{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C64 Program",
            "type": "shell",
            "command": "64tass",
            "args": [
                "--cbm-prg",
                "-o",
                "${workspaceFolder}/bin/hello.prg",
                "${workspaceFolder}/src/000-toolchain/hello.asm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}
